<div class="modal fade" id="contact-modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">New message for <%= @trade.user.name %></h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <%= form_tag email_trade_path, id: "email-trade" do %>
            <%= hidden_field_tag :trade_id, @trade.id %>

          <div class="form-group">
            <label for="message-text" class="col-form-label">Your Username: </label>
            <%= text_field_tag :username, nil, class: "form-control", id: "message-text" %>
          </div> 

          <div class="form-group">
            <label for="message-email" class="col-form-label">Email: </label>
            <%= text_field_tag :email, nil, class: "form-control", id: "message-email" %>
          </div>

           <div class="form-group">
            <label for="message-text" class="col-form-label">Message: </label>
            <textarea class="form-control" id="message-text"></textarea>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
        <button type="button" class="btn btn-success" id="send-mesage-to-trade">Send message</button>
      </div>
    </div>
  </div>
</div> 